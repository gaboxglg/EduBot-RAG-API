{
  "openapi": "3.0.0",
  "info": {
    "title": "EduBot RAG API",
    "version": "1.0.0",
    "description": "API REST de asistencia educativa inteligente utilizando el modelo RAG, base de datos vectorial en Supabase y autenticación JWT."
  },
  "servers": [
    {
      "url": "http://localhost:3000",
      "description": "Servidor Local"
    },
    {
      "url": "https://edubot-rag-api.onrender.com",
      "description": "Servidor de Producción"
    }
  ],
  "components": {
    "securitySchemes": {
      "BearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT",
        "description": "Ingrese el token JWT obtenido en el endpoint de login para autenticarse."
      }
    }
  },
  "paths": {
    "/api/v1/auth/login": {
      "post": {
        "summary": "Iniciar sesión de usuario",
        "description": "Permite obtener un token JWT válido utilizando credenciales simuladas.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "email": { "type": "string", "example": "admin@edubot.com" },
                  "password": { "type": "string", "example": "123456" }
                },
                "required": ["email", "password"]
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Login exitoso. Devuelve el token." },
          "401": { "description": "Credenciales inválidas." }
        }
      }
    },
    "/api/v1/chat/ask": {
      "post": {
        "summary": "Consultar al EduBot (RAG)",
        "description": "Envía una pregunta al sistema para ser procesada con el contexto de Supabase y respondida por Gemini. Requiere autenticación.",
        "security": [{ "BearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "question": { "type": "string", "example": "¿Cómo se representan las pilas en UML?" }
                },
                "required": ["question"]
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Respuesta generada correctamente por la IA." },
          "401": { "description": "Token inválido o expirado." },
          "403": { "description": "Falta el token de autenticación." }
        }
      }
    },
    "/api/v1/documents": {
      "get": {
        "summary": "Obtener todos los documentos",
        "description": "Devuelve una lista de todos los fragmentos de documentos almacenados en la base de datos (READ del CRUD).",
        "security": [{ "BearerAuth": [] }],
        "responses": {
          "200": { "description": "Lista de documentos obtenida con éxito." },
          "401": { "description": "Token inválido o expirado." },
          "500": { "description": "Error interno del servidor." }
        }
      }
    },
    "/api/v1/documents/upload": {
      "post": {
        "summary": "Subir e ingestar un documento PDF",
        "description": "Recibe un archivo PDF, extrae su texto, lo divide en chunks, genera los embeddings vectoriales y los guarda en Supabase (CREATE del CRUD).",
        "security": [{ "BearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "multipart/form-data": {
              "schema": {
                "type": "object",
                "properties": {
                  "file": {
                    "type": "string",
                    "format": "binary",
                    "description": "El archivo PDF a procesar"
                  }
                },
                "required": ["file"]
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Documento procesado y guardado con éxito." },
          "400": { "description": "No se envió archivo o el PDF está vacío." },
          "401": { "description": "Token inválido o expirado." }
        }
      }
    },
    "/api/v1/documents/{id}": {
      "put": {
        "summary": "Actualizar un documento",
        "description": "Actualiza el texto de un fragmento de documento específico en la base de datos (UPDATE del CRUD).",
        "security": [{ "BearerAuth": [] }],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "description": "El ID del documento en Supabase",
            "schema": { "type": "string" }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "content": { "type": "string", "example": "Texto corregido para el fragmento..." }
                },
                "required": ["content"]
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Documento actualizado correctamente." },
          "400": { "description": "Falta el contenido a actualizar." },
          "401": { "description": "Token inválido o expirado." }
        }
      },
      "delete": {
        "summary": "Eliminar un documento",
        "description": "Elimina un fragmento de documento específico de la base de datos (DELETE del CRUD).",
        "security": [{ "BearerAuth": [] }],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "description": "El ID del documento a eliminar en Supabase",
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": { "description": "Documento eliminado correctamente." },
          "401": { "description": "Token inválido o expirado." },
          "500": { "description": "Error interno del servidor." }
        }
      }
    }
  }
}