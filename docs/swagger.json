{
  "openapi": "3.0.0",
  "info": {
    "title": "EduBot RAG API",
    "version": "1.0.0",
    "description": "API REST de asistencia educativa inteligente utilizando el modelo RAG, base de datos vectorial en Supabase y autenticación JWT."
  },
  "servers": [
    {
      "url": "http://localhost:3000",
      "description": "Servidor Local"
    },
    {
      "url": "https://edubot-rag-api.onrender.com",
      "description": "Servidor de Producción"
    }
  ],
  "components": {
    "securitySchemes": {
      "BearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT",
        "description": "Ingrese el token JWT obtenido en el endpoint de login para autenticarse."
      }
    }
  },
  "paths": {
    "/api/v1/auth/login": {
      "post": {
        "summary": "Iniciar sesión de usuario",
        "description": "Permite obtener un token JWT válido utilizando credenciales simulaadas.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "email": { "type": "string", "example": "admin@edubot.com" },
                  "password": { "type": "string", "example": "123456" }
                },
                "required": ["email", "password"]
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Login exitoso. Devuelve el token." },
          "401": { "description": "Credenciales inválidas." }
        }
      }
    },
    "/api/v1/chat/ask": {
      "post": {
        "summary": "Consultar al EduBot (RAG)",
        "description": "Envía una pregunta al sistema para ser procesada con el contexto de Supabase y respondida por Gemini. Requiere autenticación.",
        "security": [{ "BearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "question": { "type": "string", "example": "¿Cómo se representan las pilas en UML?" }
                },
                "required": ["question"]
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Respuesta generada correctamente por la IA." },
          "401": { "description": "Token inválido o expirado." },
          "403": { "description": "Falta el token de autenticación." }
        }
      }
    },
    "/api/v1/documents/upload": {
      "post": {
        "summary": "Subir e ingestar un documento PDF",
        "description": "Recibe un archivo PDF, extrae su texto, lo divide en chunks, genera los embeddings vectoriales con Gemini y los guarda en Supabase.",
        "security": [{ "BearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "multipart/form-data": {
              "schema": {
                "type": "object",
                "properties": {
                  "file": {
                    "type": "string",
                    "format": "binary",
                    "description": "El archivo PDF a procesar"
                  }
                },
                "required": ["file"]
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Documento procesado y guardado con éxito." },
          "400": { "description": "No se envió archivo o el PDF está vacío." },
          "401": { "description": "Token inválido o expirado." }
        }
      }
    }
  }
}